# Copy to `.env` and adjust. All values are optional — the pipeline runs fully
# offline against bundled fixtures with no configuration at all.

# Set to 1 to force offline mode (use bundled fixtures, never hit the network).
# Default is 0 (live APIs), but the CLI `--offline` flag overrides this.
DIRPIPE_OFFLINE=0

# Override the default authoritative source endpoints if needed.
DIRPIPE_NPPES_BASE_URL=https://npiregistry.cms.hhs.gov/api/
DIRPIPE_CMS_BASE_URL=https://data.cms.gov/provider-data/api/1/datastore/query/
DIRPIPE_CENSUS_BASE_URL=https://geocoding.geo.census.gov/geocoder/

# Network timeout (seconds) for source HTTP calls.
DIRPIPE_HTTP_TIMEOUT=15

# Transient-error (429/5xx) retries with exponential backoff for live API calls.
DIRPIPE_HTTP_RETRIES=3

# Cache live API responses on disk (cost lever). Set to 0 to disable.
DIRPIPE_HTTP_CACHE=1
DIRPIPE_HTTP_CACHE_TTL=86400

# Full NUCC taxonomy->specialty crosswalk CSV (defaults to the bundled subset).
# DIRPIPE_TAXONOMY_CSV=/path/to/nucc_taxonomy.csv

# Where the append-only audit log is written.
DIRPIPE_AUDIT_PATH=audit_log.jsonl

# Logging level: DEBUG, INFO, WARNING, ERROR.
DIRPIPE_LOG_LEVEL=INFO
